SLIDESHOW_DIR=C:\Users\admin\Dropbox\slideshow
REPLAY_VIDEO_PATH=C:\ReplayTrove\INSTANTREPLAY.mkv
MPV_PATH=C:\ReplayTrove\mpv\mpv.exe
MPV_EXIT_HOTKEY=Ctrl+Alt+q
REPLAY_STOP_HOTKEY=Ctrl+Alt+e
MPV_EMBEDDED=0
SYNTHETIC_FOCUS_CLICK=1
# Chords: Ctrl+Shift+g, Alt+m, Ctrl+Alt+F1, etc. Plain g still works (no +).
# Stream Deck must emit the same modifiers + key.
RECORDING_MAX_MINUTES=20
RECORDING_START_HOTKEY=Ctrl+Shift+g
RECORDING_DISMISS_HOTKEY=Ctrl+Alt+m
# Recording overlay PNGs (relative to working directory when you run main.py)
RECORDING_OVERLAY_WIDTH=538
RECORDING_OVERLAY_HEIGHT=189
RECORDING_PROGRESS_IMAGE_ON=assets/recording/inprogress-on.png
RECORDING_PROGRESS_IMAGE_OFF=assets/recording/inprogress-off.png
RECORDING_ENDED_IMAGE=assets/recording/recording-ended.png
# Timer position: pixels right and down from the top-left of the overlay graphic (538x189 canvas).
# Optional fractions default to 0 when using offsets only.
RECORDING_OVERLAY_TIMER_X_FRAC=0
RECORDING_OVERLAY_TIMER_Y_FRAC=0
RECORDING_OVERLAY_TIMER_OFFSET_X_PX=430
RECORDING_OVERLAY_TIMER_OFFSET_Y_PX=50
# Timer text: negative = height in pixels (Tk); positive = point size (e.g. 22).
RECORDING_OVERLAY_TIMER_FONT_SIZE=-53
# How long the max-length message stays if no one dismisses it (minutes, min 1).
# When RECORDING_ENDED_IMAGE is set, auto-dismiss uses RECORDING_ENDED_GRAPHIC_HOLD_MS (default 10s) instead.
RECORDING_ENDED_HOLD_MINUTES=2
# Toggle distraction-free black screen (scores locked; replay still works).
BLACK_SCREEN_HOTKEY=Ctrl+Shift+b
RECORDING_OBS_HEALTH_CHECK=1
RECORDING_OBS_BLOCK_IF_MAIN_RECORDING=0
RECORDING_OBS_HEALTH_FAIL_CLOSED=0
OBS_RESTART_CHORD_ENABLED=1
# Optional if OBS is not in the default path:
# OBS_EXECUTABLE=C:\Program Files\obs-studio\bin\64bit\obs64.exe
OBS_RESTART_LAUNCH_ARGS=--disable-shutdown-check
# pip: obsws-python (for starting replay buffer after launch)
OBS_WEBSOCKET_HOST=127.0.0.1
# OBS_WEBSOCKET_PORT=4455
# OBS_WEBSOCKET_PASSWORD=...
OBS_RESTART_START_REPLAY_BUFFER=1
OBS_RESTART_POST_LAUNCH_DELAY_MS=7000
OBS_STATUS_INDICATOR_ENABLED=1
OBS_STATUS_POLL_INTERVAL_MS=5000
OBS_STATUS_REQUIRE_MAIN_OUTPUT_IDLE=0